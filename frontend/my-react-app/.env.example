# Auth0 (required for Google sign-in and login)
# Copy from Auth0 Dashboard → Applications → Your SPA app
VITE_AUTH0_DOMAIN=dev-your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_client_id_here
VITE_AUTH0_AUDIENCE=https://mediexplain-api
VITE_API_URL=http://localhost:8000

# IMPORTANT: Add http://localhost:5173 to Auth0 → Application → Allowed Callback URLs
