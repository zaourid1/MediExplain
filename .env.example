# =============================================
# MediExplain - Environment Variables
# =============================================
# Copy this file to .env and fill in your keys
# cp .env.example .env

# --- REQUIRED ---

# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here


# --- OPTIONAL: ElevenLabs (for audio explanations) ---

# Get from: https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=

# Voice ID — default is "Bella" (calm, clear female voice)
# Browse voices at: https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL


# --- OPTIONAL: Cloudinary (for image hosting) ---

# Get from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=


# --- APP SETTINGS ---

# Max upload size in MB
MAX_FILE_SIZE_MB=10
